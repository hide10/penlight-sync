{
  "name": "penlight-sync",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n VITE,SERVER -c cyan,yellow \"vite\" \"tsx watch server.ts\"",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist-server/server.js",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.server.json"
  },
  "dependencies": {
    "express": "^5.1.0",
    "qrcode": "^1.5.4",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.30",
    "@types/qrcode": "^1.5.5",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
